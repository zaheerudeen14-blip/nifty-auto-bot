{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/heatmap",
      "schedule": "*/3 3-10 * * 1-5"
    },
    {
      "path": "/api/cron/summary",
      "schedule": "*/15 3-10 * * 1-5"
    }
  ]
}
